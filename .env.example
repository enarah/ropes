# Local development database only. Do not commit real credentials.
DATABASE_URL="postgresql://ropes_user:ropes_password@localhost:5432/ropes_dev?schema=public"

# Auth.js / NextAuth local setup. Use generated local secrets only.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Required and checked at runtime in production. Use the same stable value on
# every app instance. Generate a dedicated secret with: openssl rand -base64 32
APPB_MAPPING_REVIEW_HISTORY_CURSOR_SECRET=""

# Optional Google OAuth provider.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional Microsoft Entra ID OAuth provider.
MICROSOFT_ENTRA_ID_CLIENT_ID=""
MICROSOFT_ENTRA_ID_CLIENT_SECRET=""
MICROSOFT_ENTRA_ID_TENANT_ID=""

# Required before saving Fulcrum API tokens. Generate a local key with:
# openssl rand -base64 32
FULCRUM_TOKEN_ENCRYPTION_KEY=""

# Optional override for the server-side Fulcrum credential test endpoint.
FULCRUM_CONNECTION_TEST_URL="https://api.fulcrumapp.com/api/v2/users.json"
