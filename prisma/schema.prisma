generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrganisationType {
  ENARAH
  PARTNER
  DEMO
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum TripStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TripApprovalState {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  CHANGES_REQUESTED
  CANCELLED
}

enum TripRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum VehicleStatus {
  AVAILABLE
  BOOKED
  MAINTENANCE
  RETIRED
}

enum BookingStatus {
  REQUESTED
  APPROVED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum VehicleDefectCategory {
  MECHANICAL
  SAFETY
  TYRES
  ELECTRICAL
  COMMUNICATIONS
  RECOVERY_GEAR
  BODY
  OTHER
}

enum VehicleDefectSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VehicleDefectStatus {
  OPEN
  MONITORING
  RESOLVED
}

enum VehicleMaintenanceType {
  SERVICE
  REPAIR
  INSPECTION
  TYRES
  REGISTRATION
  CLEANING
  OTHER
}

enum VehicleMaintenanceStatus {
  COMPLETED
  SCHEDULED
  DEFERRED
}

enum FulcrumConnectionStatus {
  NOT_CONNECTED
  READY_FOR_SETUP
  CONNECTED
  ERROR
}

enum FulcrumSyncJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum GrantFunder {
  NIAA
  DCCEEW
  OTHER
}

enum GrantProgramType {
  IRP
  IPA
  MDBIRR
  OTHER
}

enum GrantStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum GrantReportingCycle {
  ANNUAL_PLANNING
  MID_YEAR_PROGRESS
  ANNUAL_ACQUITTAL
}

enum GrantReportingPeriodStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum AppbReportStatus {
  DRAFT
  IN_REVIEW
  READY
  EXPORTED
}

enum AppbManualFieldStatus {
  BLANK
  DRAFT
  ENTERED
  NEEDS_REVIEW
  REVIEWED
  NOT_APPLICABLE
}

enum AppbManualFieldSensitivity {
  NORMAL
  FINANCE
  PERSONNEL
  NARRATIVE
  SENSITIVE
}

enum AppbManualFieldType {
  SHORT_TEXT
  LONG_TEXT
  NUMBER
  CURRENCY
  DATE
  YES_NO
  SELECT
  ROW_GROUP_PLACEHOLDER
}

enum AppbMappingReviewTargetKind {
  FIELD_MAPPING
  REPEATABLE_RANGE
}

enum AppbMappingReviewDecision {
  KEEP_NEEDS_REVIEW
  MARK_REVIEWED
  MARK_BLOCKED_FORMULA
  MARK_BLOCKED_HIDDEN_SHEET
  MARK_BLOCKED_UNSUPPORTED
  MARK_UNMAPPED
  MARK_READY_FOR_FUTURE_EXPORT
}

enum AppbMappingReviewStatus {
  UNMAPPED
  NEEDS_REVIEW
  REVIEWED
  BLOCKED_FORMULA
  BLOCKED_HIDDEN_SHEET
  BLOCKED_UNSUPPORTED
  READY_FOR_FUTURE_EXPORT
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  REJECTED
  APPROVED
  EXPORTED
  SYNC_STARTED
  SYNC_FAILED
  PERMISSION_CHANGED
}

model Organisation {
  id                               String                                   @id @default(cuid())
  name                             String
  slug                             String                                   @unique
  type                             OrganisationType                         @default(PARTNER)
  isDemo                           Boolean                                  @default(false)
  createdAt                        DateTime                                 @default(now())
  updatedAt                        DateTime                                 @updatedAt
  capabilities                     OrganisationCapability[]
  memberships                      Membership[]
  projects                         Project[]
  rangerPrograms                   RangerProgram[]
  trips                            Trip[]
  tripRiskAssessments              TripRiskAssessment[]
  tripApprovalNotes                TripApprovalNote[]
  tripParticipants                 TripParticipant[]
  tripVehicleAllocations           TripVehicleAllocation[]
  tripItineraryItems               TripItineraryItem[]
  vehicles                         Vehicle[]
  vehicleBookings                  VehicleBooking[]
  vehicleDefects                   VehicleDefect[]
  vehicleMaintenanceRecords        VehicleMaintenanceRecord[]
  vehiclePreStartChecklists        VehiclePreStartChecklist[]
  fulcrumConnections               FulcrumConnection[]
  fulcrumSyncJobs                  FulcrumSyncJob[]
  fulcrumApps                      FulcrumApp[]
  fulcrumRecords                   FulcrumRecord[]
  grants                           Grant[]
  grantReportingPeriods            GrantReportingPeriod[]
  appbReports                      AppbReport[]
  appbManualFieldValues            AppbManualFieldValue[]
  appbMappingReviewDecisions       AppbMappingReviewDecisionRecord[]
  appbMappingReviewDecisionHistory AppbMappingReviewDecisionHistoryRecord[]
  auditLogs                        AuditLog[]
}

model OrganisationCapability {
  id             String       @id @default(cuid())
  organisationId String
  key            String
  moduleKey      String
  isDemo         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@unique([organisationId, key])
  @@index([organisationId])
  @@index([key])
  @@index([moduleKey])
}

model User {
  id                         String                     @id @default(cuid())
  name                       String
  email                      String                     @unique
  isDemo                     Boolean                    @default(false)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  memberships                Membership[]
  auditLogs                  AuditLog[]
  tripsLed                   Trip[]                     @relation("TripLead")
  tripApprovalNotes          TripApprovalNote[]
  tripParticipants           TripParticipant[]
  tripRiskAssessmentsCreated TripRiskAssessment[]       @relation("TripRiskAssessmentCreatedBy")
  tripRiskAssessmentsUpdated TripRiskAssessment[]       @relation("TripRiskAssessmentUpdatedBy")
  vehicleBookings            VehicleBooking[]
  vehicleDefects             VehicleDefect[]
  vehicleMaintenanceRecords  VehicleMaintenanceRecord[]
  vehiclePreStartChecklists  VehiclePreStartChecklist[]
  fulcrumSyncJobs            FulcrumSyncJob[]
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
}

model Membership {
  id             String           @id @default(cuid())
  organisationId String
  userId         String
  roleId         String
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organisation   Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([organisationId, userId])
  @@index([userId])
  @@index([roleId])
}

model Project {
  id             String          @id @default(cuid())
  organisationId String
  name           String
  code           String
  description    String
  fundingStream  String?
  startsOn       DateTime?
  endsOn         DateTime?
  isDemo         Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organisation   Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  rangerPrograms RangerProgram[]
  trips          Trip[]
  fulcrumApps    FulcrumApp[]
  fulcrumRecords FulcrumRecord[]
  grants         Grant[]

  @@unique([organisationId, code])
  @@index([organisationId])
}

model RangerProgram {
  id             String       @id @default(cuid())
  organisationId String
  projectId      String?
  name           String
  description    String
  region         String
  isDemo         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  trips          Trip[]
  grants         Grant[]

  @@index([organisationId])
  @@index([projectId])
}

model Trip {
  id                 String                  @id @default(cuid())
  organisationId     String
  projectId          String?
  rangerProgramId    String?
  leadUserId         String?
  title              String
  purpose            String
  status             TripStatus              @default(DRAFT)
  approvalStatus     TripApprovalState       @default(DRAFT)
  destination        String
  startsAt           DateTime
  endsAt             DateTime
  isDemo             Boolean                 @default(false)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  organisation       Organisation            @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  project            Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  rangerProgram      RangerProgram?          @relation(fields: [rangerProgramId], references: [id], onDelete: SetNull)
  leadUser           User?                   @relation("TripLead", fields: [leadUserId], references: [id], onDelete: SetNull)
  approvalNotes      TripApprovalNote[]
  riskAssessment     TripRiskAssessment?
  participants       TripParticipant[]
  vehicleAllocations TripVehicleAllocation[]
  itineraryItems     TripItineraryItem[]
  vehicleBookings    VehicleBooking[]
  fulcrumRecords     FulcrumRecord[]

  @@index([organisationId])
  @@index([projectId])
  @@index([rangerProgramId])
  @@index([leadUserId])
  @@index([approvalStatus])
}

model TripRiskAssessment {
  id                    String        @id @default(cuid())
  organisationId        String
  tripId                String        @unique
  createdByUserId       String?
  updatedByUserId       String?
  tripTypeCode          String
  activityRiskCodes     String[]      @default([])
  baseRiskLevel         TripRiskLevel
  finalRiskLevel        TripRiskLevel
  tripSpecificControls  String?
  leadDrivers           String?
  spotGarminDetails     String?
  satellitePhone        String?
  mobilePhone           String?
  epirbDetails          String?
  firstAidDetails       String?
  defibDetails          String?
  dpfDetails            String?
  otherEquipment        String?
  rangers               String?
  partners              String?
  medicalAllergyNotes   String?
  relevantContacts      String?
  dailyItinerary        Json?
  emergencyContacts     String?
  escalationNotes       String?
  readyForManagerReview Boolean       @default(false)
  isDemo                Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  organisation          Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  trip                  Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy             User?         @relation("TripRiskAssessmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy             User?         @relation("TripRiskAssessmentUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([organisationId])
  @@index([tripId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([finalRiskLevel])
}

model TripApprovalNote {
  id                 String             @id @default(cuid())
  organisationId     String
  tripId             String
  actorUserId        String?
  fromApprovalStatus TripApprovalState?
  toApprovalStatus   TripApprovalState
  note               String
  isDemo             Boolean            @default(false)
  createdAt          DateTime           @default(now())
  organisation       Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  trip               Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  actor              User?              @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organisationId])
  @@index([tripId])
  @@index([actorUserId])
  @@index([organisationId, tripId, createdAt])
}

model TripParticipant {
  id             String       @id @default(cuid())
  organisationId String
  tripId         String
  userId         String?
  name           String
  role           String
  status         String
  rowOrder       Int
  isDemo         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  trip           Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organisationId])
  @@index([tripId])
  @@index([userId])
  @@index([organisationId, tripId, rowOrder])
}

model TripVehicleAllocation {
  id             String       @id @default(cuid())
  organisationId String
  tripId         String
  vehicleId      String?
  name           String
  registration   String
  status         String
  rowOrder       Int
  isDemo         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  trip           Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  vehicle        Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([organisationId])
  @@index([tripId])
  @@index([vehicleId])
  @@index([organisationId, tripId, rowOrder])
}

model TripItineraryItem {
  id             String       @id @default(cuid())
  organisationId String
  tripId         String
  day            String
  title          String
  description    String
  rowOrder       Int
  startsAt       DateTime?
  endsAt         DateTime?
  location       String?
  isDemo         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  trip           Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([organisationId])
  @@index([tripId])
  @@index([organisationId, tripId, rowOrder])
}

model Vehicle {
  id                     String                     @id @default(cuid())
  organisationId         String
  name                   String
  registration           String
  make                   String
  model                  String
  year                   Int?
  status                 VehicleStatus              @default(AVAILABLE)
  odometerKm             Int?
  isDemo                 Boolean                    @default(false)
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  organisation           Organisation               @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  tripVehicleAllocations TripVehicleAllocation[]
  vehicleBookings        VehicleBooking[]
  vehicleDefects         VehicleDefect[]
  maintenanceRecords     VehicleMaintenanceRecord[]
  preStartChecklists     VehiclePreStartChecklist[]

  @@unique([organisationId, registration])
  @@index([organisationId])
}

model VehiclePreStartChecklist {
  id                 String          @id @default(cuid())
  organisationId     String
  vehicleId          String
  submittedByUserId  String?
  odometerKm         Int
  tyresOk            Boolean
  lightsOk           Boolean
  fluidsOk           Boolean
  communicationsOk   Boolean
  recoveryGearOk     Boolean
  generalConditionOk Boolean
  issueNotes         String?
  isDemo             Boolean         @default(false)
  checkedAt          DateTime        @default(now())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  organisation       Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  vehicle            Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  submittedBy        User?           @relation(fields: [submittedByUserId], references: [id], onDelete: SetNull)
  vehicleDefects     VehicleDefect[]

  @@index([organisationId])
  @@index([vehicleId])
  @@index([submittedByUserId])
  @@index([organisationId, vehicleId, checkedAt])
}

model VehicleDefect {
  id                  String                     @id @default(cuid())
  organisationId      String
  vehicleId           String
  preStartChecklistId String?
  reportedByUserId    String?
  category            VehicleDefectCategory
  severity            VehicleDefectSeverity
  description         String
  status              VehicleDefectStatus        @default(OPEN)
  reportedAt          DateTime                   @default(now())
  isDemo              Boolean                    @default(false)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  organisation        Organisation               @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  vehicle             Vehicle                    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  preStartChecklist   VehiclePreStartChecklist?  @relation(fields: [preStartChecklistId], references: [id], onDelete: SetNull)
  reportedBy          User?                      @relation(fields: [reportedByUserId], references: [id], onDelete: SetNull)
  maintenanceRecords  VehicleMaintenanceRecord[]

  @@index([organisationId])
  @@index([vehicleId])
  @@index([preStartChecklistId])
  @@index([reportedByUserId])
  @@index([status])
  @@index([organisationId, vehicleId, status, reportedAt])
}

model VehicleMaintenanceRecord {
  id               String                   @id @default(cuid())
  organisationId   String
  vehicleId        String
  defectId         String?
  recordedByUserId String?
  type             VehicleMaintenanceType
  status           VehicleMaintenanceStatus @default(COMPLETED)
  provider         String?
  maintenanceDate  DateTime
  odometerKm       Int?
  costCents        Int?
  notes            String?
  nextDueDate      DateTime?
  isDemo           Boolean                  @default(false)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  organisation     Organisation             @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  vehicle          Vehicle                  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  defect           VehicleDefect?           @relation(fields: [defectId], references: [id], onDelete: SetNull)
  recordedBy       User?                    @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)

  @@index([organisationId])
  @@index([vehicleId])
  @@index([defectId])
  @@index([recordedByUserId])
  @@index([status])
  @@index([organisationId, vehicleId, maintenanceDate])
}

model VehicleBooking {
  id             String        @id @default(cuid())
  organisationId String
  vehicleId      String
  tripId         String?
  bookedByUserId String?
  status         BookingStatus @default(REQUESTED)
  startsAt       DateTime
  endsAt         DateTime
  notes          String?
  isDemo         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organisation   Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  vehicle        Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip           Trip?         @relation(fields: [tripId], references: [id], onDelete: SetNull)
  bookedBy       User?         @relation(fields: [bookedByUserId], references: [id], onDelete: SetNull)

  @@index([organisationId])
  @@index([vehicleId])
  @@index([tripId])
  @@index([bookedByUserId])
}

model FulcrumConnection {
  id                String                  @id @default(cuid())
  organisationId    String
  name              String
  status            FulcrumConnectionStatus @default(NOT_CONNECTED)
  accountLabel      String?
  encryptedApiToken String?
  tokenHint         String?
  lastCheckedAt     DateTime?
  lastTestMessage   String?
  lastSyncedAt      DateTime?
  disabledAt        DateTime?
  isDemo            Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  organisation      Organisation            @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  fulcrumApps       FulcrumApp[]
  fulcrumRecords    FulcrumRecord[]
  fulcrumSyncJobs   FulcrumSyncJob[]

  @@index([organisationId])
}

model FulcrumSyncJob {
  id                  String               @id @default(cuid())
  organisationId      String
  fulcrumConnectionId String
  requestedByUserId   String?
  status              FulcrumSyncJobStatus @default(QUEUED)
  safeErrorCategory   String?
  summary             String
  metadata            Json?
  requestedAt         DateTime             @default(now())
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organisation        Organisation         @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  fulcrumConnection   FulcrumConnection    @relation(fields: [fulcrumConnectionId], references: [id], onDelete: Cascade)
  requestedBy         User?                @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([organisationId])
  @@index([fulcrumConnectionId])
  @@index([requestedByUserId])
  @@index([status])
}

model FulcrumApp {
  id                  String             @id @default(cuid())
  organisationId      String
  fulcrumConnectionId String?
  projectId           String?
  name                String
  description         String
  externalAppId       String?
  recordCount         Int                @default(0)
  lastSyncedAt        DateTime?
  importedAt          DateTime?
  rawJson             Json?
  isDemo              Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organisation        Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  fulcrumConnection   FulcrumConnection? @relation(fields: [fulcrumConnectionId], references: [id], onDelete: SetNull)
  project             Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  fulcrumRecords      FulcrumRecord[]

  @@unique([organisationId, fulcrumConnectionId, externalAppId])
  @@index([organisationId])
  @@index([fulcrumConnectionId])
  @@index([projectId])
}

model FulcrumRecord {
  id                  String             @id @default(cuid())
  organisationId      String
  fulcrumConnectionId String?
  fulcrumAppId        String
  projectId           String?
  tripId              String?
  externalRecordId    String?
  status              String
  latitude            Float?
  longitude           Float?
  capturedAt          DateTime?
  importedAt          DateTime?
  dataHealthFlags     Json?
  rawJson             Json
  isDemo              Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organisation        Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  fulcrumConnection   FulcrumConnection? @relation(fields: [fulcrumConnectionId], references: [id], onDelete: SetNull)
  fulcrumApp          FulcrumApp         @relation(fields: [fulcrumAppId], references: [id], onDelete: Cascade)
  project             Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  trip                Trip?              @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@unique([organisationId, fulcrumConnectionId, externalRecordId])
  @@index([organisationId])
  @@index([fulcrumConnectionId])
  @@index([fulcrumAppId])
  @@index([projectId])
  @@index([tripId])
}

model Grant {
  id                         String                            @id @default(cuid())
  organisationId             String
  projectId                  String?
  rangerProgramId            String?
  funder                     GrantFunder
  programType                GrantProgramType
  title                      String
  fundingAgreementNumber     String?
  fundingPeriodStart         DateTime
  fundingPeriodEnd           DateTime
  status                     GrantStatus                       @default(ACTIVE)
  isDemo                     Boolean                           @default(false)
  createdAt                  DateTime                          @default(now())
  updatedAt                  DateTime                          @updatedAt
  organisation               Organisation                      @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  project                    Project?                          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  rangerProgram              RangerProgram?                    @relation(fields: [rangerProgramId], references: [id], onDelete: SetNull)
  reportingPeriods           GrantReportingPeriod[]
  appbReports                AppbReport[]
  appbManualFieldValues      AppbManualFieldValue[]
  appbMappingReviewDecisions AppbMappingReviewDecisionRecord[]

  @@index([organisationId])
  @@index([projectId])
  @@index([rangerProgramId])
  @@index([funder])
  @@index([programType])
  @@index([status])
  @@index([organisationId, fundingPeriodStart, fundingPeriodEnd])
}

model GrantReportingPeriod {
  id                     String                            @id @default(cuid())
  organisationId         String
  grantId                String
  label                  String
  cycle                  GrantReportingCycle
  startsOn               DateTime
  endsOn                 DateTime
  dueOn                  DateTime?
  status                 GrantReportingPeriodStatus        @default(DRAFT)
  isDemo                 Boolean                           @default(false)
  createdAt              DateTime                          @default(now())
  updatedAt              DateTime                          @updatedAt
  organisation           Organisation                      @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  grant                  Grant                             @relation(fields: [grantId], references: [id], onDelete: Cascade)
  appbReports            AppbReport[]
  manualFieldValues      AppbManualFieldValue[]
  mappingReviewDecisions AppbMappingReviewDecisionRecord[]

  @@index([organisationId])
  @@index([grantId])
  @@index([cycle])
  @@index([status])
  @@index([organisationId, grantId, startsOn])
}

model AppbReport {
  id                           String                                   @id @default(cuid())
  organisationId               String
  grantId                      String
  reportingPeriodId            String
  templateProfileId            String
  templateVersionLabel         String
  status                       AppbReportStatus                         @default(DRAFT)
  manualFieldSummary           String?
  missingDataSummary           String?
  exportedAt                   DateTime?
  isDemo                       Boolean                                  @default(false)
  createdAt                    DateTime                                 @default(now())
  updatedAt                    DateTime                                 @updatedAt
  organisation                 Organisation                             @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  grant                        Grant                                    @relation(fields: [grantId], references: [id], onDelete: Cascade)
  reportingPeriod              GrantReportingPeriod                     @relation(fields: [reportingPeriodId], references: [id], onDelete: Cascade)
  manualFieldValues            AppbManualFieldValue[]
  mappingReviewDecisions       AppbMappingReviewDecisionRecord[]
  mappingReviewDecisionHistory AppbMappingReviewDecisionHistoryRecord[]

  @@index([organisationId])
  @@index([grantId])
  @@index([reportingPeriodId])
  @@index([status])
  @@index([organisationId, grantId, reportingPeriodId])
}

model AppbManualFieldValue {
  id                String                     @id @default(cuid())
  organisationId    String
  grantId           String
  reportingPeriodId String
  appbReportId      String
  fieldId           String
  fieldLabel        String
  fieldGroup        String
  fieldType         AppbManualFieldType
  sensitivity       AppbManualFieldSensitivity
  status            AppbManualFieldStatus      @default(BLANK)
  valueText         String?
  valueNumber       Decimal?                   @db.Decimal(12, 2)
  valueDate         DateTime?
  notes             String?
  isDemo            Boolean                    @default(false)
  createdByUserId   String?
  updatedByUserId   String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  organisation      Organisation               @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  grant             Grant                      @relation(fields: [grantId], references: [id], onDelete: Cascade)
  reportingPeriod   GrantReportingPeriod       @relation(fields: [reportingPeriodId], references: [id], onDelete: Cascade)
  appbReport        AppbReport                 @relation(fields: [appbReportId], references: [id], onDelete: Cascade)

  @@unique([organisationId, appbReportId, fieldId])
  @@index([organisationId])
  @@index([grantId])
  @@index([reportingPeriodId])
  @@index([appbReportId])
  @@index([fieldGroup])
  @@index([status])
  @@index([sensitivity])
}

model AppbMappingReviewDecisionRecord {
  id                  String                                   @id @default(cuid())
  organisationId      String
  grantId             String
  reportingPeriodId   String
  appbReportId        String
  templateVersionId   String
  targetKind          AppbMappingReviewTargetKind
  targetId            String
  decision            AppbMappingReviewDecision
  reviewStatus        AppbMappingReviewStatus
  safeNote            String?
  reviewerUserId      String?
  reviewerDisplayName String?
  reviewedAt          DateTime
  auditMetadataJson   Json?
  createdAt           DateTime                                 @default(now())
  updatedAt           DateTime                                 @updatedAt
  organisation        Organisation                             @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  grant               Grant                                    @relation(fields: [grantId], references: [id], onDelete: Cascade)
  reportingPeriod     GrantReportingPeriod                     @relation(fields: [reportingPeriodId], references: [id], onDelete: Cascade)
  appbReport          AppbReport                               @relation(fields: [appbReportId], references: [id], onDelete: Cascade)
  historyRecords      AppbMappingReviewDecisionHistoryRecord[]

  @@unique([organisationId, appbReportId, targetKind, targetId])
  @@index([organisationId])
  @@index([grantId])
  @@index([reportingPeriodId])
  @@index([appbReportId])
  @@index([templateVersionId])
  @@index([targetKind])
  @@index([decision])
  @@index([reviewStatus])
}

model AppbMappingReviewDecisionHistoryRecord {
  id                   String                          @id @default(cuid())
  organisationId       String
  appbReportId         String
  reviewDecisionId     String
  templateVersionId    String
  targetKind           AppbMappingReviewTargetKind
  targetId             String
  previousDecision     AppbMappingReviewDecision?
  previousReviewStatus AppbMappingReviewStatus?
  newDecision          AppbMappingReviewDecision
  newReviewStatus      AppbMappingReviewStatus
  reviewerUserId       String?
  reviewerDisplayName  String?
  reviewedAt           DateTime
  safeNote             String?
  valueFree            Boolean                         @default(true)
  createdAt            DateTime                        @default(now())
  organisation         Organisation                    @relation(fields: [organisationId], references: [id], onDelete: Cascade, map: "AppbReviewHistory_organisationId_fkey")
  appbReport           AppbReport                      @relation(fields: [appbReportId], references: [id], onDelete: Cascade, map: "AppbReviewHistory_appbReportId_fkey")
  reviewDecision       AppbMappingReviewDecisionRecord @relation(fields: [reviewDecisionId], references: [id], onDelete: Cascade, map: "AppbReviewHistory_reviewDecisionId_fkey")

  @@index([organisationId], map: "AppbReviewHistory_organisationId_idx")
  @@index([appbReportId], map: "AppbReviewHistory_appbReportId_idx")
  @@index([reviewDecisionId], map: "AppbReviewHistory_reviewDecisionId_idx")
  @@index([templateVersionId], map: "AppbReviewHistory_templateVersionId_idx")
  @@index([organisationId, appbReportId, targetKind, targetId, reviewedAt], map: "AppbReviewHistory_target_reviewedAt_idx")
}

model AuditLog {
  id             String       @id @default(cuid())
  organisationId String
  actorUserId    String?
  action         AuditAction
  entityType     String
  entityId       String?
  summary        String
  metadata       Json?
  createdAt      DateTime     @default(now())
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  actor          User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organisationId])
  @@index([actorUserId])
  @@index([entityType, entityId])
}
